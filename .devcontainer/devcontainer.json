{
  "name": "IVAE Studios — cloud editor",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" }
  },
  "postCreateCommand": "pip install -r scripts/requirements.txt && echo 'Codespace ready. Run: python scripts/audit_links.py'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true
      }
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "Site preview", "onAutoForward": "notify" }
  }
}
