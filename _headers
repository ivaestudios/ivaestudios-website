# ═══════════════════════════════════════════
# SECURITY & PERFORMANCE HEADERS
# ═══════════════════════════════════════════

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://wa.me; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://wa.me; upgrade-insecure-requests

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/images/*
  Cache-Control: public, max-age=31536000, immutable

# Gallery JS / CSS — declared BEFORE the site-wide catch-alls so they win.
# Cloudflare Pages applies the FIRST matching rule for each header.
# These files don't carry content hashes, so they need short TTL + revalidate.
/gallery/js/*.js
  Cache-Control: public, max-age=300, must-revalidate

/gallery/admin/*.js
  Cache-Control: public, max-age=0, must-revalidate

/gallery/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Service-Worker-Allowed: /

/gallery/css/*.css
  Cache-Control: public, max-age=300, must-revalidate

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/focal-admin.js
  Cache-Control: public, max-age=0, must-revalidate

/api/*
  Cache-Control: no-cache

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

# ═══════════════════════════════════════════
# GALLERY SUB-APP (mounted at /gallery/, API at /api/gallery/)
# Override the strict main-site CSP — the gallery app needs to talk to
# Cloudflare R2 (presigned PUTs), the local IVAE Uploader daemon
# (127.0.0.1:9876), and Dropbox upload endpoints. It also relies on
# inline event handlers throughout the admin pages.
# ═══════════════════════════════════════════

/gallery/*
  Content-Security-Policy: default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; img-src 'self' data: blob: https: http:; media-src 'self' https: blob:; connect-src 'self' https: http://localhost:9876 http://127.0.0.1:9876; worker-src 'self' blob:; frame-src 'self' https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/api/gallery/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Admin pages — never cache (deploys propagate immediately)
/gallery/admin/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache

/gallery/admin/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# Gallery client view itself — fresh HTML, but immutable assets stay cached
/gallery/gallery.html
  Cache-Control: public, max-age=0, must-revalidate

# (Gallery JS/CSS rules are declared at the top of this file — before
#  the site-wide /*.js and /*.css catch-alls — so the first-match-wins
#  precedence in Cloudflare Pages applies them correctly.)

# Login + auth pages — fresh HTML
/gallery/index.html
  Cache-Control: public, max-age=0, must-revalidate

/gallery/galleries.html
  Cache-Control: public, max-age=0, must-revalidate
